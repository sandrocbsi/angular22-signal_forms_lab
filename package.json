{
  "name": "temp-angular-22",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^22.0.0-next.5",
    "@angular/compiler": "^22.0.0-next.5",
    "@angular/core": "^22.0.0-next.5",
    "@angular/forms": "^22.0.0-next.5",
    "@angular/platform-browser": "^22.0.0-next.5",
    "@angular/router": "^22.0.0-next.5",
    "@js-joda/core": "^6.0.0",
    "ngx-currency": "^19.0.0",
    "ngx-mask": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "ngx-currency": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms"
    },
    "ngx-mask": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms"
    }
  },
  "devDependencies": {
    "@angular/build": "^22.0.0-next.3",
    "@angular/cli": "^22.0.0-next.3",
    "@angular/compiler-cli": "^22.0.0-next.5",
    "jsdom": "^27.1.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
